# ============================================================================
# Warehouse-CRM (Household Chemicals) — environment variables
# ============================================================================
# Copy this file to .env.local (or .env) and fill in real values.
# NEVER commit .env / .env.local — they are in .gitignore.

# === REQUIRED: Supabase (self-hosted) ===
# Public URL of the Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.example.com

# Anonymous public key (used by the frontend). Has read-only / RLS-bound access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-SIDE ONLY (Telegram webhook). Bypasses RLS.
# Do not expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# === REQUIRED: Telegram bot ===
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret token that Telegram echoes back in the
# X-Telegram-Bot-Api-Secret-Token header. Register the webhook with:
#   curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -F "url=https://<host>/api/telegram/webhook" \
#     -F "secret_token=<this value>"
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# === REQUIRED: Poster API (master data source) ===
# Token from Poster admin → Settings → Apps → REST API
POSTER_TOKEN=

# Poster account slug (subdomain), e.g. "my-shop" from my-shop.joinposter.com
POSTER_ACCOUNT=
